[flake8]
# Max line length — 100 is a pragmatic modern default
max-line-length = 100

# Exclude generated/vendor dirs
exclude =
    venv,
    __pycache__,
    .git,
    *.egg-info,
    dist,
    build

# Ignore rules that conflict with Black or are overly pedantic
extend-ignore =
    # E501: line too long (handled by max-line-length above)
    E501,
    # W503: line break before binary operator (conflicts with Black)
    W503,
    # E203: whitespace before ':' (conflicts with Black slices)
    E203,
    # E402: module level import not at top of file
    E402,
    # E741: ambiguous variable name
    E741,
    # W293: blank line contains whitespace
    W293,
    # E302: expected 2 blank lines
    E302,
    # E303: too many blank lines
    E303,
    # W391: blank line at end of file
    W391,
    # E712: comparison to True should be 'if cond is True:' or 'if cond:'
    E712,
    # F401: module imported but unused (common in __init__.py exports)
    F401,
    # W291: trailing whitespace
    W291,
    # F541: f-string is missing placeholders
    F541,
    # E261: at least two spaces before inline comment
    E261
